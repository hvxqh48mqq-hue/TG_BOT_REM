import asyncio
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.fsm.state import StatesGroup, State
from aiogram.fsm.context import FSMContext
import aiosqlite
from datetime import datetime, timedelta
import pytz

API_TOKEN = "YOUR_TOKEN"

bot = Bot(token=API_TOKEN)
dp = Dispatcher()

# ================= STATES =================
class CreateReminder(StatesGroup):
    text = State()
    time = State()
    days = State()
    date = State()
    notify_before = State()
    timezone = State()

class EditReminder(StatesGroup):
    text = State()
    time = State()
    days = State()
    date = State()

# ================= DB =================
async def init_db():
    async with aiosqlite.connect("db.db") as db:
        await db.execute("""
        CREATE TABLE IF NOT EXISTS reminders (
            id INTEGER PRIMARY KEY,
            user_id INTEGER,
            text TEXT,
            time TEXT,
            days TEXT,
            date TEXT,
            notify_before INTEGER,
            timezone TEXT
        )
        """)
        await db.commit()

# ================= UI =================
def main_menu():
    return InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="➕ Создать", callback_data="create"),
            InlineKeyboardButton(text="📋 Мои", callback_data="list")
        ]
    ])

def days_keyboard(selected=[]):
    names = ["Пн","Вт","Ср","Чт","Пт","Сб","Вс"]
    kb = []
    row = []
    for i, d in enumerate(names, 1):
        text = f"✅ {d}" if str(i) in selected else d
        row.append(InlineKeyboardButton(text=text, callback_data=f"day_{i}"))
        if len(row) == 3:
            kb.append(row)
            row = []
    if row:
        kb.append(row)

    kb.append([InlineKeyboardButton(text="Готово", callback_data="done_days")])
    return InlineKeyboardMarkup(inline_keyboard=kb)

def reminder_card(r):
    id, _, text, time, days, date, before, tz = r

    days_text = days if days else "—"
    date_text = date if date else "—"

    return f"""
📌 <b>{text}</b>
🆔 ID: {id}
⏰ {time}
📅 Дни: {days_text}
📆 Дата: {date_text}
⏳ За: {before} мин
🌍 {tz}
"""

# ================= START =================
@dp.message(Command("start"))
async def start(msg: types.Message):
    await msg.answer("🚀 <b>Менеджер напоминаний</b>", reply_markup=main_menu(), parse_mode="HTML")

# ================= CREATE =================
@dp.callback_query(F.data == "create")
async def create(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("Введите текст:")
    await state.set_state(CreateReminder.text)

@dp.message(CreateReminder.text)
async def set_text(msg: types.Message, state: FSMContext):
    await state.update_data(text=msg.text)
    await msg.answer("Введите время (HH:MM):")
    await state.set_state(CreateReminder.time)

@dp.message(CreateReminder.time)
async def set_time(msg: types.Message, state: FSMContext):
    await state.update_data(time=msg.text)

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="📅 Разовое", callback_data="one")],
        [InlineKeyboardButton(text="🔁 Повтор", callback_data="repeat")]
    ])
    await msg.answer("Тип:", reply_markup=kb)

# --- repeat ---
@dp.callback_query(F.data == "repeat")
async def repeat(call: types.CallbackQuery, state: FSMContext):
    await state.update_data(days=[])
    await call.message.answer("Выбери дни:", reply_markup=days_keyboard())
    await state.set_state(CreateReminder.days)

@dp.callback_query(F.data.startswith("day_"))
async def pick_day(call: types.CallbackQuery, state: FSMContext):
    data = await state.get_data()
    days = data.get("days", [])

    d = call.data.split("_")[1]
    if d in days:
        days.remove(d)
    else:
        days.append(d)

    await state.update_data(days=days)
    await call.message.edit_reply_markup(reply_markup=days_keyboard(days))

@dp.callback_query(F.data == "done_days")
async def done_days(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("За сколько минут напомнить?")
    await state.set_state(CreateReminder.notify_before)

# --- one time ---
@dp.callback_query(F.data == "one")
async def one(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("Введите дату (YYYY-MM-DD):")
    await state.set_state(CreateReminder.date)

@dp.message(CreateReminder.date)
async def set_date(msg: types.Message, state: FSMContext):
    await state.update_data(date=msg.text)
    await msg.answer("За сколько минут напомнить?")
    await state.set_state(CreateReminder.notify_before)

# --- notify + tz ---
@dp.message(CreateReminder.notify_before)
async def set_before(msg: types.Message, state: FSMContext):
    await state.update_data(notify_before=int(msg.text))
    await msg.answer("Часовой пояс (например Europe/Berlin):")
    await state.set_state(CreateReminder.timezone)

@dp.message(CreateReminder.timezone)
async def save(msg: types.Message, state: FSMContext):
    data = await state.get_data()

    async with aiosqlite.connect("db.db") as db:
        await db.execute("""
        INSERT INTO reminders (user_id, text, time, days, date, notify_before, timezone)
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (
            msg.from_user.id,
            data.get("text"),
            data.get("time"),
            ",".join(data.get("days", [])),
            data.get("date"),
            data.get("notify_before"),
            data.get("timezone")
        ))
        await db.commit()

    await msg.answer("✅ Сохранено!", reply_markup=main_menu())
    await state.clear()

# ================= LIST =================
@dp.callback_query(F.data == "list")
async def list_reminders(call: types.CallbackQuery):
    async with aiosqlite.connect("db.db") as db:
        async with db.execute("SELECT * FROM reminders WHERE user_id=?", (call.from_user.id,)) as cur:
            rows = await cur.fetchall()

    for r in rows:
        kb = InlineKeyboardMarkup(inline_keyboard=[
            [
                InlineKeyboardButton(text="✏️", callback_data=f"edit_{r[0]}"),
                InlineKeyboardButton(text="❌", callback_data=f"del_{r[0]}")
            ]
        ])
        await call.message.answer(reminder_card(r), parse_mode="HTML", reply_markup=kb)

# ================= DELETE =================
@dp.callback_query(F.data.startswith("del_"))
async def delete(call: types.CallbackQuery):
    rid = call.data.split("_")[1]

    async with aiosqlite.connect("db.db") as db:
        await db.execute("DELETE FROM reminders WHERE id=?", (rid,))
        await db.commit()

    await call.message.answer("❌ Удалено")

# ================= EDIT =================
@dp.callback_query(F.data.startswith("edit_"))
async def edit_menu(call: types.CallbackQuery, state: FSMContext):
    rid = call.data.split("_")[1]
    await state.update_data(edit_id=rid)

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Текст", callback_data="et")],
        [InlineKeyboardButton(text="Время", callback_data="etm")],
        [InlineKeyboardButton(text="Дни", callback_data="ed")],
        [InlineKeyboardButton(text="Дата", callback_data="eda")]
    ])
    await call.message.answer("Что изменить?", reply_markup=kb)

@dp.callback_query(F.data == "et")
async def edit_text(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("Новый текст:")
    await state.set_state(EditReminder.text)

@dp.message(EditReminder.text)
async def save_text(msg: types.Message, state: FSMContext):
    rid = (await state.get_data())["edit_id"]

    async with aiosqlite.connect("db.db") as db:
        await db.execute("UPDATE reminders SET text=? WHERE id=?", (msg.text, rid))
        await db.commit()

    await msg.answer("✅ Обновлено")
    await state.clear()

# Аналогично можно расширить остальные поля (время, дни, дата)

# ================= SCHEDULER =================
async def scheduler():
    while True:
        now = datetime.utcnow()

        async with aiosqlite.connect("db.db") as db:
            async with db.execute("SELECT * FROM reminders") as cur:
                rows = await cur.fetchall()

        for r in rows:
            _, user_id, text, time_str, days, date, before, tz = r

            try:
                tz_obj = pytz.timezone(tz)
                local_now = now.astimezone(tz_obj)

                reminder_time = datetime.strptime(time_str, "%H:%M").time()
                target_time = datetime.combine(local_now.date(), reminder_time) - timedelta(minutes=before)

                if date:
                    if local_now.strftime("%Y-%m-%d") == date:
                        if abs((local_now - target_time).seconds) < 60:
                            await bot.send_message(user_id, f"⏰ {text}")

                elif days:
                    if str(local_now.isoweekday()) in days.split(","):
                        if abs((local_now - target_time).seconds) < 60:
                            await bot.send_message(user_id, f"⏰ {text}")

            except:
                pass

        await asyncio.sleep(60)

# ================= RUN =================
async def main():
    await init_db()
    asyncio.create_task(scheduler())
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
