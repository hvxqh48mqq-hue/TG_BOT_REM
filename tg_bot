import asyncio
from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.fsm.state import StatesGroup, State
from aiogram.fsm.context import FSMContext
import aiosqlite
from datetime import datetime, timedelta
import pytz

API_TOKEN = "YOUR_TOKEN"

bot = Bot(token=API_TOKEN)
dp = Dispatcher()

# --- Состояния ---
class CreateReminder(StatesGroup):
    text = State()
    time = State()
    days = State()
    date = State()
    notify_before = State()
    timezone = State()

# --- БД ---
async def init_db():
    async with aiosqlite.connect("db.db") as db:
        await db.execute("""
        CREATE TABLE IF NOT EXISTS reminders (
            id INTEGER PRIMARY KEY,
            user_id INTEGER,
            text TEXT,
            time TEXT,
            days TEXT,
            date TEXT,
            notify_before INTEGER,
            timezone TEXT
        )
        """)
        await db.commit()

# --- Кнопки дней ---
def days_keyboard(selected=[]):
    days = ["Пн","Вт","Ср","Чт","Пт","Сб","Вс"]
    kb = []
    for i, d in enumerate(days, start=1):
        text = f"✅ {d}" if str(i) in selected else d
        kb.append([InlineKeyboardButton(text=text, callback_data=f"day_{i}")])
    kb.append([InlineKeyboardButton(text="Готово", callback_data="done_days")])
    return InlineKeyboardMarkup(inline_keyboard=kb)

# --- Старт ---
@dp.message(Command("start"))
async def start(msg: types.Message):
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="➕ Создать", callback_data="create")],
        [InlineKeyboardButton(text="📋 Мои напоминания", callback_data="list")]
    ])
    await msg.answer("Выбери действие:", reply_markup=kb)

# --- Создание ---
@dp.callback_query(F.data == "create")
async def create(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("Введите текст:")
    await state.set_state(CreateReminder.text)

@dp.message(CreateReminder.text)
async def set_text(msg: types.Message, state: FSMContext):
    await state.update_data(text=msg.text)
    await msg.answer("Введите время (HH:MM):")
    await state.set_state(CreateReminder.time)

@dp.message(CreateReminder.time)
async def set_time(msg: types.Message, state: FSMContext):
    await state.update_data(time=msg.text)
    
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="📅 Разовое", callback_data="one_time")],
        [InlineKeyboardButton(text="🔁 Повторяющееся", callback_data="repeat")]
    ])
    
    await msg.answer("Тип события:", reply_markup=kb)

# --- Тип ---
@dp.callback_query(F.data == "repeat")
async def repeat(call: types.CallbackQuery, state: FSMContext):
    await state.update_data(days=[])
    await call.message.answer("Выбери дни:", reply_markup=days_keyboard())
    await state.set_state(CreateReminder.days)

@dp.callback_query(F.data.startswith("day_"))
async def toggle_day(call: types.CallbackQuery, state: FSMContext):
    data = await state.get_data()
    days = data.get("days", [])
    
    day = call.data.split("_")[1]
    
    if day in days:
        days.remove(day)
    else:
        days.append(day)
    
    await state.update_data(days=days)
    await call.message.edit_reply_markup(reply_markup=days_keyboard(days))

@dp.callback_query(F.data == "done_days")
async def done_days(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("За сколько минут напомнить заранее?")
    await state.set_state(CreateReminder.notify_before)

# --- Разовое ---
@dp.callback_query(F.data == "one_time")
async def one_time(call: types.CallbackQuery, state: FSMContext):
    await call.message.answer("Введите дату (YYYY-MM-DD):")
    await state.set_state(CreateReminder.date)

@dp.message(CreateReminder.date)
async def set_date(msg: types.Message, state: FSMContext):
    await state.update_data(date=msg.text)
    await msg.answer("За сколько минут напомнить заранее?")
    await state.set_state(CreateReminder.notify_before)

# --- Напоминание заранее ---
@dp.message(CreateReminder.notify_before)
async def notify_before(msg: types.Message, state: FSMContext):
    await state.update_data(notify_before=int(msg.text))
    await msg.answer("Введите часовой пояс (например Europe/Berlin):")
    await state.set_state(CreateReminder.timezone)

# --- Таймзона и сохранение ---
@dp.message(CreateReminder.timezone)
async def save(msg: types.Message, state: FSMContext):
    data = await state.get_data()
    data["timezone"] = msg.text

    async with aiosqlite.connect("db.db") as db:
        await db.execute("""
        INSERT INTO reminders (user_id, text, time, days, date, notify_before, timezone)
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (
            msg.from_user.id,
            data.get("text"),
            data.get("time"),
            ",".join(data.get("days", [])),
            data.get("date"),
            data.get("notify_before"),
            data.get("timezone")
        ))
        await db.commit()

    await msg.answer("✅ Сохранено!")
    await state.clear()

# --- Список ---
@dp.callback_query(F.data == "list")
async def list_reminders(call: types.CallbackQuery):
    async with aiosqlite.connect("db.db") as db:
        async with db.execute("SELECT id, text FROM reminders WHERE user_id=?", (call.from_user.id,)) as cur:
            rows = await cur.fetchall()

    kb = []
    for r in rows:
        kb.append([
            InlineKeyboardButton(text=r[1], callback_data=f"view_{r[0]}")
        ])

    await call.message.answer("Твои напоминания:", reply_markup=InlineKeyboardMarkup(inline_keyboard=kb))

# --- Удаление ---
@dp.callback_query(F.data.startswith("view_"))
async def view(call: types.CallbackQuery):
    rid = call.data.split("_")[1]
    
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="❌ Удалить", callback_data=f"del_{rid}")]
    ])
    
    await call.message.answer(f"Напоминание ID {rid}", reply_markup=kb)

@dp.callback_query(F.data.startswith("del_"))
async def delete(call: types.CallbackQuery):
    rid = call.data.split("_")[1]
    
    async with aiosqlite.connect("db.db") as db:
        await db.execute("DELETE FROM reminders WHERE id=?", (rid,))
        await db.commit()
    
    await call.message.answer("Удалено!")

# --- Планировщик ---
async def scheduler():
    while True:
        now = datetime.utcnow()

        async with aiosqlite.connect("db.db") as db:
            async with db.execute("SELECT * FROM reminders") as cur:
                rows = await cur.fetchall()

        for r in rows:
            _, user_id, text, time_str, days, date, before, tz = r

            try:
                tz_obj = pytz.timezone(tz)
                local_now = now.astimezone(tz_obj)

                reminder_time = datetime.strptime(time_str, "%H:%M").time()

                target_time = datetime.combine(local_now.date(), reminder_time) - timedelta(minutes=before)

                # Разовое
                if date:
                    target_date = datetime.strptime(date, "%Y-%m-%d").date()
                    if local_now.date() == target_date and abs((local_now - target_time).seconds) < 60:
                        await bot.send_message(user_id, f"⏰ {text}")

                # Повторяющееся
                elif days:
                    if str(local_now.isoweekday()) in days.split(","):
                        if abs((local_now - target_time).seconds) < 60:
                            await bot.send_message(user_id, f"⏰ {text}")

            except:
                pass

        await asyncio.sleep(60)

# --- Запуск ---
async def main():
    await init_db()
    asyncio.create_task(scheduler())
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
